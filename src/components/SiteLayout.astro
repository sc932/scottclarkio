---
import {
  navLinks,
  personSchema,
  websiteSchema,
  buildBreadcrumbList,
  siteUrl,
} from "../lib/site-content";

interface Props {
  /** <title> */
  pageTitle: string;
  /** <meta name="description"> */
  pageDescription: string;
  /** Background color. */
  bg: string;
  /** Primary text color. */
  ink: string;
  /** Muted secondary text. */
  mute: string;
  /** Even softer (labels, copyright). */
  soft: string;
  /** Hover/link accent. */
  accent: string;
  /** Hairline rule color. */
  rule: string;
  /** Soft rule (between rows). */
  ruleSoft: string;
  /** CSS font-family stack for display. */
  serif: string;
  /** CSS font-family stack for body. */
  sans: string;
  /** og:type override; defaults to "website" (use "profile" on /, "article" on blog posts). */
  ogType?: string;
  /** Optional page-specific JSON-LD entity (ProfilePage, CollectionPage, etc.) appended to the @graph. */
  pageSchema?: object | null;
  /** Optional path to preload as image (for above-the-fold LCP), e.g. "/images/scott-clark.jpg". */
  preloadImage?: string | null;
}

const {
  pageTitle,
  pageDescription,
  bg,
  ink,
  mute,
  soft,
  accent,
  rule,
  ruleSoft,
  serif,
  sans,
  ogType = "website",
  pageSchema = null,
  preloadImage = null,
} = Astro.props;

// Canonical URL + .md twin for AIO discovery hint.
// Path is normalized: strip trailing slash; root maps to /index.md.
const normalizedPath = Astro.url.pathname.replace(/\/$/, "");
const canonicalPath = normalizedPath === "" ? "/" : normalizedPath;
const mdTwinPath =
  normalizedPath === "" ? "/index.md" : `${normalizedPath}.md`;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}/images/scott-clark.jpg`;

// Build a single JSON-LD @graph: Person + WebSite + BreadcrumbList + (optional)
// page-specific entity. Strip @context from inner nodes since the outer wrapper
// declares it once.
const stripContext = <T extends { "@context"?: unknown }>(node: T) => {
  const { "@context": _ctx, ...rest } = node;
  return rest;
};
const breadcrumbList = buildBreadcrumbList(canonicalPath);
const jsonLdGraph = {
  "@context": "https://schema.org",
  "@graph": [
    stripContext(personSchema),
    stripContext(websiteSchema),
    stripContext(breadcrumbList),
    ...(pageSchema ? [stripContext(pageSchema as { "@context"?: unknown })] : []),
  ],
};

// rel="me" identity claims: link to every profile in personSchema.sameAs plus mailto.
const relMeLinks = [...personSchema.sameAs, `mailto:${personSchema.email}`];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    {/* Indexing signals */}
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="Scott Clark" />
    <meta name="application-name" content="Scott Clark" />

    {/* Theming */}
    <meta name="theme-color" content="#fbf9f4" />
    <meta name="color-scheme" content="light" />

    {/* Favicon variants */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#1c1916" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    {/* Canonical + alternate representations */}
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="text/markdown"
      href={mdTwinPath}
      title="Plain markdown version (for LLM ingestion)"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Scott Clark — RSS"
      href="/rss.xml"
    />
    <link
      rel="sitemap"
      type="application/xml"
      title="Sitemap"
      href="/sitemap-index.xml"
    />

    {/* IndieWeb identity claims (rel=me) */}
    {relMeLinks.map((href) => <link rel="me" href={href} />)}
    <link rel="author" href={`${siteUrl}/`} />

    {/* Above-the-fold image preload (per-page opt-in) */}
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Scott Clark" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Scott Clark" />
    {ogType === "profile" && (
      <>
        <meta property="profile:first_name" content="Scott" />
        <meta property="profile:last_name" content="Clark" />
        <meta property="profile:username" content="DrScottClark" />
      </>
    )}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Scott Clark" />
    <meta name="twitter:creator" content="@DrScottClark" />
    <meta name="twitter:site" content="@DrScottClark" />

    {/* Structured data: Person + WebSite + BreadcrumbList + (optional) page entity, all in one @graph. */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdGraph)}
    />
  </head>

  <body>
    <header class="masthead">
      <div class="masthead-inner">
        <a class="wordmark" href="/">Scott Clark</a>
        <nav>
          {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
        </nav>
      </div>
    </header>

    <main>
      <slot />

      <footer class="endnotes">
        <p>
          Resume: <a href="/resume/scott-clark-resume.pdf">PDF</a> · Source: <a
            href="https://github.com/sc932/resume">github.com/sc932/resume</a
          >
        </p>
        <p class="copy">© 2026 Scott Clark</p>
      </footer>
    </main>

    <style
      is:global
      define:vars={{ bg, ink, mute, soft, accent, rule, ruleSoft, serif, sans }}
    >
      *,
      *::before,
      *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 17px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: var(--rule);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s ease, color 0.15s ease;
      }
      a:hover { color: var(--accent); text-decoration-color: var(--accent); }
      strong { font-weight: 600; color: var(--ink); }
      em { font-style: italic; color: inherit; }

      /* Masthead */
      .masthead {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--bg);
        border-bottom: 1px solid var(--rule);
      }
      .masthead-inner {
        max-width: 880px;
        margin: 0 auto;
        padding: 14px 32px;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 24px;
      }
      .wordmark {
        font-family: var(--serif);
        font-weight: 500;
        font-size: 19px;
        text-decoration: none;
        color: var(--ink);
      }
      .wordmark:hover { color: var(--accent); }
      .masthead nav {
        display: flex;
        gap: 22px;
        font-size: 14.5px;
        color: var(--mute);
      }
      .masthead nav a { text-decoration: none; color: var(--mute); }
      .masthead nav a:hover { color: var(--accent); }

      main {
        max-width: 880px;
        margin: 0 auto;
        padding: 56px 32px 96px;
      }

      /* Page header (subpages) */
      .page-head {
        margin-bottom: 56px;
        padding-bottom: 22px;
        border-bottom: 1px solid var(--rule);
      }
      .page-head h1 {
        font-family: var(--serif);
        font-weight: 500;
        font-size: 48px;
        line-height: 1.05;
        letter-spacing: -0.012em;
        margin: 0 0 8px;
      }
      .page-head .sub {
        margin: 0;
        color: var(--mute);
        font-size: 17px;
        line-height: 1.5;
        max-width: 620px;
      }

      /* Home — intro */
      .intro {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 36px;
        align-items: start;
        margin-bottom: 64px;
      }
      .meta-col { display: flex; flex-direction: column; gap: 18px; }
      .portrait-wrap {
        background: #fff;
        padding: 6px;
        border: 1px solid var(--rule);
        border-radius: 4px;
        box-shadow: 0 1px 2px rgba(31, 28, 25, 0.04),
          0 6px 18px rgba(31, 28, 25, 0.05);
        line-height: 0;
      }
      .portrait {
        width: 100%;
        height: auto;
        object-fit: cover;
        border-radius: 2px;
        display: block;
      }

      .socials {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .socials li { line-height: 1; }
      .socials a {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--ink);
        text-decoration: none;
        font-size: 14px;
        padding: 4px 0;
        line-height: 1.2;
      }
      .socials a:hover { color: var(--accent); }
      .socials .icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        display: block;
        color: inherit;
      }

      .intro-text h1 {
        font-family: var(--serif);
        font-weight: 500;
        font-size: 56px;
        line-height: 1.05;
        letter-spacing: -0.015em;
        margin: -8px 0 8px;
      }
      .byline {
        margin: 0 0 18px;
        color: var(--mute);
        font-size: 16px;
        line-height: 1.45;
      }
      .byline a { color: var(--mute); }
      .byline a:hover { color: var(--accent); }

      .lede {
        margin: 0 0 18px;
        font-size: 17px;
        line-height: 1.6;
      }

      .bullets {
        list-style: none;
        padding: 0;
        margin: 0;
        border-top: 1px solid var(--rule);
      }
      .bullets li {
        padding: 12px 0;
        border-bottom: 1px solid var(--rule);
        font-size: 16px;
        line-height: 1.55;
      }

      /* Section blocks shared by home + CV */
      .block { margin-top: 56px; }
      .block-label {
        font-family: var(--sans);
        font-weight: 500;
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--soft);
        margin: 0 0 24px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--rule);
      }

      /* Chronological rows */
      .rows { list-style: none; padding: 0; margin: 0; }
      .row {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 22px;
        padding: 18px 0 22px;
        border-bottom: 1px solid var(--ruleSoft);
      }
      .row:last-child { border-bottom: none; }
      .row-period {
        font-size: 14px;
        color: var(--mute);
        padding-top: 3px;
        font-variant-numeric: tabular-nums;
      }
      .row-head {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 6px 14px;
        margin-bottom: 6px;
      }
      .row-org {
        font-family: var(--serif);
        font-weight: 500;
        font-size: 21px;
        line-height: 1.2;
        letter-spacing: -0.005em;
      }
      .row-title {
        font-size: 15px;
        color: var(--mute);
      }
      .row-desc {
        margin: 0;
        font-size: 16px;
        line-height: 1.55;
        color: var(--ink);
      }
      .row-bullets {
        list-style: none;
        padding: 0;
        margin: 0;
        font-size: 16px;
        line-height: 1.55;
        color: var(--ink);
      }
      .row-bullets li {
        position: relative;
        padding-left: 18px;
        margin-bottom: 4px;
      }
      .row-bullets li:last-child { margin-bottom: 0; }
      .row-bullets li::before {
        content: "—";
        position: absolute;
        left: 0;
        color: var(--soft);
      }
      .row-links {
        margin: 8px 0 0;
        font-size: 14px;
        color: var(--mute);
      }
      .row-links a { color: var(--mute); }
      .row-links a:hover { color: var(--accent); }
      .row-links .sep {
        margin: 0 6px;
        color: var(--soft);
      }

      /* Project rows — full width, no period column */
      .project-rows { list-style: none; padding: 0; margin: 0; }
      .project-row {
        padding: 22px 0 26px;
        border-bottom: 1px solid var(--ruleSoft);
      }
      .project-row:last-child { border-bottom: none; }
      .project-row .row-head { margin-bottom: 8px; }
      .project-row .row-org { font-size: 22px; }
      .project-tags {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 6px 12px;
        margin-left: 4px;
        font-size: 13px;
        color: var(--soft);
      }
      .project-tags li { display: inline; }

      /* Endnotes */
      .endnotes {
        margin-top: 72px;
        padding-top: 22px;
        border-top: 1px solid var(--rule);
        font-size: 13.5px;
        color: var(--mute);
        line-height: 1.55;
      }
      .endnotes p { margin: 0 0 6px; }
      .endnotes a { color: var(--mute); }
      .endnotes a:hover { color: var(--accent); }
      .copy { color: var(--soft); }

      @media (max-width: 720px) {
        main { padding: 40px 22px 72px; }
        .masthead-inner { padding: 12px 22px; }
        .intro { grid-template-columns: 1fr; gap: 24px; }
        .meta-col { flex-direction: row; flex-wrap: wrap; align-items: flex-start; }
        .portrait-wrap { width: 160px; }
        .socials { flex: 1; min-width: 200px; }
        .intro-text h1 { font-size: 44px; }
        .page-head h1 { font-size: 36px; }
        .row { grid-template-columns: 1fr; gap: 6px; }
        .row-period { font-size: 13px; }
      }
    </style>
  </body>
</html>
