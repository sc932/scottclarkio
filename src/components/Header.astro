---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/publications", label: "Publications" },
  { href: "/talks", label: "Talks" },
  { href: "/press", label: "Press" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-surface-lighter bg-surface/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="text-xl font-bold tracking-tight text-text-primary hover:text-accent-light transition-colors">
      Scott Clark
    </a>

    <!-- Desktop nav -->
    <ul class="hidden gap-1 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "rounded-lg px-3 py-2 text-sm font-medium transition-colors",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "bg-accent/10 text-accent-light"
                : "text-text-secondary hover:bg-surface-light hover:text-text-primary",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="rounded-lg p-2 text-text-secondary hover:bg-surface-light md:hidden"
      aria-label="Toggle menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden border-t border-surface-lighter md:hidden">
    <ul class="flex flex-col gap-1 px-6 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block rounded-lg px-3 py-2 text-sm font-medium transition-colors",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "bg-accent/10 text-accent-light"
                : "text-text-secondary hover:bg-surface-light hover:text-text-primary",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
