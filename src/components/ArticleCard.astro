---
interface Props {
  title: string;
  publication: string;
  date: Date;
  url: string;
  excerpt?: string;
}

const { title, publication, date, url, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="group rounded-xl border border-surface-lighter bg-surface-light/50 p-6 transition-all hover:border-accent/30 hover:bg-surface-light">
  <div class="mb-2 flex items-center gap-2 text-sm text-text-muted">
    <span class="font-semibold text-accent-light">{publication}</span>
    <span>&middot;</span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>

  <h3 class="mb-2 text-lg font-bold leading-snug text-text-primary group-hover:text-accent-light transition-colors">
    <a href={url} target="_blank" rel="noopener noreferrer">
      {title}
    </a>
  </h3>

  {excerpt && (
    <p class="text-sm leading-relaxed text-text-secondary line-clamp-2">
      {excerpt}
    </p>
  )}

  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-accent-light hover:text-accent transition-colors"
  >
    Read Article &rarr;
  </a>
</article>
