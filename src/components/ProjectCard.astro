---
interface Props {
  title: string;
  description: string;
  url?: string;
  repo?: string;
  image?: string;
  tags: string[];
}

const { title, description, url, repo, image, tags } = Astro.props;
---

<article class="group flex flex-col overflow-hidden rounded-xl border border-surface-lighter bg-surface-light/50 transition-all hover:border-accent/30 hover:bg-surface-light">
  {image && (
    <div class="aspect-video overflow-hidden bg-surface-lighter">
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform group-hover:scale-105"
        loading="lazy"
      />
    </div>
  )}

  <div class="flex flex-1 flex-col p-6">
    <h3 class="mb-2 text-lg font-bold text-text-primary group-hover:text-accent-light transition-colors">
      {title}
    </h3>

    <p class="mb-4 flex-1 text-sm leading-relaxed text-text-secondary">
      {description}
    </p>

    <div class="mb-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent-light">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex gap-3">
      {url && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-accent-light hover:text-accent transition-colors"
        >
          View Project &rarr;
        </a>
      )}
      {repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-text-muted hover:text-text-secondary transition-colors"
        >
          Source Code
        </a>
      )}
    </div>
  </div>
</article>
