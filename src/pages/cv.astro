---
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/ibm-plex-sans";
import SiteLayout from "../components/SiteLayout.astro";
import { v2Theme } from "../lib/site-theme";
import { education, buildProfilePageSchema } from "../lib/site-content";
import {
  cvExperience,
  researchPracticums,
  awards,
  advisory,
  focusAreas,
  selectedPubs,
  selectedTalks,
} from "../lib/cv-content";

const cvPageSchema = buildProfilePageSchema({
  pathname: "/cv",
  name: "CV — Scott Clark",
  description:
    "Long-form CV for Scott Clark: complete career history, education, awards, advisory, research areas, and selected publications and talks.",
});
---

<SiteLayout
  {...v2Theme}
  pageTitle="CV — Scott Clark"
  pageDescription="Long-form CV for Scott Clark: complete career history, education, awards, advisory, research areas, and selected publications and talks."
  pageSchema={cvPageSchema}
>
  <header class="page-head">
    <h1>CV</h1>
    <p class="sub">
      Long-form curriculum vitae. The short version lives on <a href="/"
        >the home page</a
      >. Downloadable PDFs: <a href="/resume/scott-clark-resume.pdf"
        >two-page resume</a
      > and the longer <a href="/resume/scott-clark-cv.pdf">academic CV</a>. Full
      LaTeX source and a structured markdown profile are in <a
        href="https://github.com/sc932/resume">github.com/sc932/resume</a
      >.
    </p>
  </header>

  <section class="block">
    <h2 class="block-label">Experience</h2>
    <ol class="rows">
      {
        cvExperience.map((row) => {
          const list = row.cvBullets ?? row.bullets;
          return (
            <li class="row">
              <div class="row-period">{row.period}</div>
              <div class="row-body">
                <div class="row-head">
                  <span class="row-org">{row.org}</span>
                  <span class="row-title">{row.title}</span>
                </div>
                {list && (
                  <ul class="row-bullets">
                    {list.map((b) => (
                      <li set:html={b} />
                    ))}
                  </ul>
                )}
                {row.body && !list && (
                  <p class="row-desc" set:html={row.body} />
                )}
              </div>
            </li>
          );
        })
      }
    </ol>
  </section>

  <section class="block">
    <h2 class="block-label">Education</h2>
    <ol class="rows">
      {
        education.map((row) => (
          <li class="row">
            <div class="row-period">{row.period}</div>
            <div class="row-body">
              <div class="row-head">
                <span class="row-org">{row.org}</span>
                <span class="row-title">{row.title}</span>
              </div>
              <p class="row-desc" set:html={row.body} />
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="block">
    <h2 class="block-label">Research Experience</h2>
    <ol class="rows">
      {
        researchPracticums.map((row) => (
          <li class="row">
            <div class="row-period">{row.period}</div>
            <div class="row-body">
              <div class="row-head">
                <span class="row-org">{row.org}</span>
                <span class="row-title">{row.title}</span>
              </div>
              <ul class="row-bullets">
                {row.cvBullets!.map((b) => (
                  <li set:html={b} />
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="block">
    <h2 class="block-label">Awards &amp; Honors</h2>
    <ol class="rows">
      {
        awards.map((a) => (
          <li class="row">
            <div class="row-period">{a.period}</div>
            <div class="row-body">
              <div class="row-head">
                <span class="row-org">{a.title}</span>
              </div>
              <p class="row-desc" set:html={a.body} />
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="block">
    <h2 class="block-label">Board &amp; Advisory</h2>
    <ol class="rows">
      {
        advisory.map((a) => (
          <li class="row">
            <div class="row-period">{a.period}</div>
            <div class="row-body">
              <div class="row-head">
                <span class="row-org">{a.title}</span>
                <span class="row-title">{a.role}</span>
              </div>
              <p class="row-desc" set:html={a.body} />
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="block">
    <h2 class="block-label">Research Areas</h2>
    <p class="focus-list">
      {
        focusAreas.map((area, i) => (
          <>
            {i > 0 && <span class="focus-sep"> · </span>}
            <span>{area}</span>
          </>
        ))
      }
    </p>
  </section>

  <section class="block">
    <h2 class="block-label">Selected Publications</h2>
    <ol class="rows">
      {
        selectedPubs.map((p) => (
          <li class="row">
            <div class="row-period">{p.period}</div>
            <div class="row-body">
              <div class="row-head">
                <span class="row-org">{p.title}</span>
                <span class="row-title">{p.venue}</span>
              </div>
              <p class="row-desc">{p.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
    <p class="block-pointer">
      Full publication list and abstracts on the <a href="/publications"
        >Research</a
      > page; the most up-to-date list is on <a
        href="https://scholar.google.com/citations?user=mwWbhAUAAAAJ"
        >Google Scholar</a
      > (1,200+ citations, h-index 16).
    </p>
  </section>

  <section class="block">
    <h2 class="block-label">Selected Talks &amp; Podcasts</h2>
    <ol class="rows">
      {
        selectedTalks.map((t) => (
          <li class="row">
            <div class="row-period">{t.period}</div>
            <div class="row-body">
              <div class="row-head">
                <span class="row-org">{t.title}</span>
                <span class="row-title">{t.venue}</span>
              </div>
            </div>
          </li>
        ))
      }
    </ol>
    <p class="block-pointer">
      40+ documented appearances since 2013. Full list on the <a
        href="/talks">Talks</a
      > page.
    </p>
  </section>

  <style is:global>
    .focus-list {
      margin: 0;
      font-size: 16px;
      line-height: 1.85;
      color: var(--ink);
    }
    .focus-sep {
      color: var(--soft);
    }
    .block-pointer {
      margin: 18px 0 0;
      font-size: 14.5px;
      color: var(--mute);
      line-height: 1.5;
    }
    .block-pointer a {
      color: var(--mute);
    }
    .block-pointer a:hover {
      color: var(--accent);
    }
  </style>
</SiteLayout>
