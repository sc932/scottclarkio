---
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/ibm-plex-sans";
import { getCollection } from "astro:content";
import SiteLayout from "../components/SiteLayout.astro";
import { v2Theme } from "../lib/site-theme";

const publications = (await getCollection("publications")).sort(
  (a, b) => b.data.year - a.data.year
);

const formatAuthors = (authors: string[]) =>
  authors.map((a) =>
    a === "Scott C. Clark" ? `<strong>${a}</strong>` : a
  ).join(", ");
---

<SiteLayout
  {...v2Theme}
  pageTitle="Research — Scott Clark"
  pageDescription="Peer-reviewed publications, granted patents, and academic work by Scott Clark across Bayesian optimization, machine learning, applied mathematics, and bioinformatics."
>
  <header class="page-head">
    <h1>Research</h1>
    <p class="sub">
      Peer-reviewed publications, granted patents, and academic work. Google
      Scholar lists 1,200+ citations and an h-index of 16; ~20 granted US
      patents as named inventor. A subset is shown below; the most up-to-date
      list is on <a
        href="https://scholar.google.com/citations?user=mwWbhAUAAAAJ"
        >Google Scholar</a
      >.
    </p>
  </header>

  <ol class="rows">
    {
      publications.map((p) => (
        <li class="row">
          <div class="row-period">{p.data.year}</div>
          <div class="row-body">
            <div class="row-head">
              <span class="row-org">{p.data.title}</span>
            </div>
            <p class="row-desc">
              <span set:html={formatAuthors(p.data.authors)} />
              <span class="venue">
                <em> · {p.data.venue}</em>
              </span>
            </p>
            {p.data.abstract && (
              <p class="row-desc abstract">{p.data.abstract}</p>
            )}
            {(p.data.url || p.data.doi) && (
              <p class="row-links">
                {p.data.url && <a href={p.data.url}>Link</a>}
                {p.data.url && p.data.doi && <span class="sep">·</span>}
                {p.data.doi && (
                  <a href={`https://doi.org/${p.data.doi}`}>DOI: {p.data.doi}</a>
                )}
              </p>
            )}
          </div>
        </li>
      ))
    }
  </ol>

  <style is:global>
    .abstract {
      margin-top: 6px;
      color: var(--mute);
      font-size: 15px;
      line-height: 1.5;
    }
  </style>
</SiteLayout>
