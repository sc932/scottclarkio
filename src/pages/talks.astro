---
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/ibm-plex-sans";
import { getCollection } from "astro:content";
import SiteLayout from "../components/SiteLayout.astro";
import { v2Theme } from "../lib/site-theme";

const talks = (await getCollection("talks")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmtPeriod = (d: Date) => {
  const month = d.toLocaleString("en-US", { month: "short" });
  return `${month} ${d.getFullYear()}`;
};
---

<SiteLayout
  {...v2Theme}
  pageTitle="Talks — Scott Clark"
  pageDescription="Conference talks, podcast appearances, and fireside chats by Scott Clark on AI reliability, Bayesian optimization, and AI testing."
>
  <header class="page-head">
    <h1>Talks</h1>
    <p class="sub">
      Conference talks, podcast appearances, and fireside chats. Ordered most recent first.
    </p>
  </header>

  <ol class="rows">
    {
      talks.map((t) => (
        <li class="row">
          <div class="row-period">{fmtPeriod(t.data.date)}</div>
          <div class="row-body">
            <div class="row-head">
              <span class="row-org">{t.data.title}</span>
              <span class="row-title">{t.data.event}</span>
            </div>
            <p class="row-desc">{t.data.description}</p>
            {(t.data.videoUrl || t.data.slidesUrl) && (
              <p class="row-links">
                {t.data.videoUrl && <a href={t.data.videoUrl}>Video</a>}
                {t.data.videoUrl && t.data.slidesUrl && (
                  <span class="sep">·</span>
                )}
                {t.data.slidesUrl && <a href={t.data.slidesUrl}>Slides</a>}
              </p>
            )}
          </div>
        </li>
      ))
    }
  </ol>
</SiteLayout>
