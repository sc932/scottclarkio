---
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/ibm-plex-sans";
import { getCollection } from "astro:content";
import SiteLayout from "../components/SiteLayout.astro";
import { v2Theme } from "../lib/site-theme";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmtPeriod = (d: Date) => {
  const month = d.toLocaleString("en-US", { month: "short" });
  return `${month} ${d.getFullYear()}`;
};
---

<SiteLayout
  {...v2Theme}
  pageTitle="Press — Scott Clark"
  pageDescription="External coverage and media features of Scott Clark's work — TechCrunch, Wall Street Journal, BusinessWire, Cornell Chronicle, Oregon State, and others."
>
  <header class="page-head">
    <h1>Press</h1>
    <p class="sub">
      External coverage and media features. Ordered most recent first.
    </p>
  </header>

  <ol class="rows">
    {
      articles.map((a) => (
        <li class="row">
          <div class="row-period">{fmtPeriod(a.data.date)}</div>
          <div class="row-body">
            <div class="row-head">
              <span class="row-org">{a.data.title}</span>
              <span class="row-title">{a.data.publication}</span>
            </div>
            {a.data.excerpt && <p class="row-desc">{a.data.excerpt}</p>}
            <p class="row-links">
              <a href={a.data.url}>Read</a>
            </p>
          </div>
        </li>
      ))
    }
  </ol>
</SiteLayout>
