---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects")).slice(0, 3);
---

<PageLayout
  title="Scott Clark — CEO of Distributional, Forbes 30 Under 30, Cornell PhD"
  description="Personal website of Scott Clark. CEO of Distributional. Former co-founder/CEO of SigOpt (acquired by Intel). Machine learning, Bayesian optimization, and AI reliability."
>
  <Hero
    tagline="CEO & Co-Founder, Distributional"
    title="Scott Clark"
    subtitle="Building reliable AI for the enterprise. Former co-founder/CEO of SigOpt (acquired by Intel). Forbes 30 Under 30. Cornell PhD."
  >
    <a
      href="/about"
      class="rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-light hover:shadow-accent-light/25"
    >
      About Me
    </a>
    <a
      href="/blog"
      class="rounded-lg border border-surface-lighter px-6 py-3 text-sm font-semibold text-text-primary transition-all hover:border-accent/30 hover:bg-surface-light"
    >
      Read the Blog
    </a>
  </Hero>

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-20">
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-3xl font-bold tracking-tight">Recent Posts</h2>
        <a
          href="/blog"
          class="text-sm font-medium text-accent-light hover:text-accent transition-colors"
        >
          View all &rarr;
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
            image={post.data.image}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Featured Projects -->
  {projects.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-20">
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-3xl font-bold tracking-tight">Projects</h2>
        <a
          href="/projects"
          class="text-sm font-medium text-accent-light hover:text-accent transition-colors"
        >
          View all &rarr;
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            url={project.data.url}
            repo={project.data.repo}
            image={project.data.image}
            tags={project.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Quick Links -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {[
        { href: "/publications", label: "Publications", desc: "Research papers and academic work" },
        { href: "/talks", label: "Talks", desc: "Conference talks and presentations" },
        { href: "/press", label: "Press", desc: "Articles and media mentions" },
        { href: "/about", label: "About", desc: "Bio, experience, and CV" },
      ].map((link) => (
        <a
          href={link.href}
          class="group rounded-xl border border-surface-lighter bg-surface-light/50 p-6 transition-all hover:border-accent/30 hover:bg-surface-light"
        >
          <h3 class="mb-1 font-bold text-text-primary group-hover:text-accent-light transition-colors">
            {link.label}
          </h3>
          <p class="text-sm text-text-muted">{link.desc}</p>
        </a>
      ))}
    </div>
  </section>
</PageLayout>
